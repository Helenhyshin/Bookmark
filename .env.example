# Copy to .env and fill in your keys. Do not commit .env.

# GitHub (for MCP) - https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxx

# Supabase (for MCP) - https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxx
SUPABASE_PROJECT_REF=your-project-ref

# NY Times Books API (bestsellers on dashboard) — https://developer.nytimes.com/
NYT_BOOKS_API_KEY=your-nyt-books-api-key

# Notion (MCP — @notionhq/notion-mcp-server) — https://www.notion.so/profile/integrations
# Create an internal integration, copy the secret, connect pages to it. Share the secret with teammates out-of-band; do not commit it.
NOTION_TOKEN=ntn_xxxxxxxxxxxx
